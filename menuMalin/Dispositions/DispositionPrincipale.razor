@inherits LayoutComponentBase
@using System
@inject NavigationManager Navigation
@inject IServiceAuthentification AuthService
@inject ServiceEtatAuthentification AuthState
@implements IAsyncDisposable

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm border-bottom">
    <div class="container">
        @* --- LOGO --- *@
        <a class="navbar-brand d-flex align-items-center fw-bold" href="">
            <img src="images/logo.png" alt="Logo" width="35" height="35" class="me-2 logo-circle">
            <span style="color: #2d6a4f;">MenuMalin</span>
        </a>

        @* --- BOUTON HAMBURGER --- *@
        <button class="navbar-toggler" type="button" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        @* --- CONTENU DU MENU --- *@
        <div class="@NavMenuCssClass navbar-collapse" id="navbarNavMenu">
            
            <ul class="navbar-nav mx-auto text-center">
                <li class="nav-item">
                    <NavLink class="nav-link px-3" href="" Match="NavLinkMatch.All">Accueil</NavLink>
                </li>
                @if (isAuthenticated)
                {
                    <li class="nav-item">
                        <NavLink class="nav-link px-3" href="mes-favoris">Mes Favoris</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link px-3" href="mes-creations">Mes Recettes</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link px-3" href="creer-recette">Créer une Recette</NavLink>
                    </li>
                }
                @if (isAuthenticated)
                {
                    <li class="nav-item">
                        <NavLink class="nav-link px-3" href="recettes-publiques">Recettes Partagées</NavLink>
                    </li>
                }
                <li class="nav-item">
                    <NavLink class="nav-link px-3" href="contact">Nous contacter</NavLink>
                </li>
            </ul>

            @* AUTHENTIFICATION *@
            <div class="d-flex flex-column flex-lg-row align-items-center justify-content-center">
                @if (isAuthenticated)
                {
                    <div class="dropdown">
                        <button class="btn btn-sm btn-light dropdown-toggle border-0" type="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false" aria-haspopup="true">
                            <i class="bi bi-person-circle me-1"></i> @currentUser?.Name
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 text-center text-lg-start" aria-labelledby="userDropdown">
                            <li>
                                <a class="dropdown-item text-danger" href="#" @onclick="Logout" @onclick:preventDefault>
                                    <i class="bi bi-box-arrow-right me-2"></i>Déconnexion
                                </a>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <button class="btn btn-sm btn-link text-decoration-none text-muted mb-2 mb-lg-0 me-lg-2" @onclick="Login">
                        Connexion
                    </button>
                    <button class="btn btn-sm btn-success px-4 shadow-sm fw-bold" @onclick="Register">
                        Créer un compte
                    </button>
                }
            </div>
        </div>
    </div>
</nav>

<BlazoredToasts Position="ToastPosition.TopRight"
                Timeout="5"
                IconType="IconType.FontAwesome"
                SuccessClass="toast-success"
                ErrorClass="toast-error"
                WarningClass="toast-warning"
                InfoClass="toast-info" />

<main>
    @Body
</main>

@code {
    private bool collapseNavMenu = true;
    private bool isAuthenticated = false;
    private UtilisateurAuth? currentUser;
    private System.Threading.Timer? authCheckTimer;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;

        // S'abonner aux changements d'authentification
        AuthState.AuthenticationChanged += OnAuthenticationChanged;

        // Charger l'état d'authentification depuis localStorage (persiste pendant 24h)
        await AuthState.InitializeAuthStateAsync();

        // Initialiser l'authentification
        await CheckAuthentication();

        // Timer résiduel pour les cas où l'événement est manqué (backup de sécurité - réduction à 10s)
        authCheckTimer = new System.Threading.Timer(state =>
        {
            _ = InvokeAsync(async () =>
            {
                await CheckAuthentication();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private async Task CheckAuthentication()
    {
        try
        {
            // D'abord utiliser l'état global (Singleton) s'il est disponible
            if (AuthState?.CurrentUser != null)
            {
                currentUser = AuthState.CurrentUser;
                isAuthenticated = AuthState.IsAuthenticated;
                return;
            }

            // Sinon récupérer depuis le serveur
            currentUser = await AuthService.GetCurrentUserAsync();
            isAuthenticated = currentUser?.IsAuthenticated ?? false;
        }
        catch
        {
            isAuthenticated = false;
        }
    }

    private void OnAuthenticationChanged()
    {
        // Quand l'état d'authentification change, mettre à jour les propriétés locales
        currentUser = AuthState.CurrentUser;
        isAuthenticated = AuthState.IsAuthenticated;
        StateHasChanged();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        collapseNavMenu = true;
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void Login()
    {
        Navigation.NavigateTo("/connexion");
    }

    private void Register()
    {
        Navigation.NavigateTo("/inscription");
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();

        // Nettoyer l'état d'authentification global (y compris localStorage)
        await AuthState.ClearAuthStateAsync();

        // Rediriger vers l'accueil
        Navigation.NavigateTo("/");
    }

    ValueTask IAsyncDisposable.DisposeAsync()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        AuthState.AuthenticationChanged -= OnAuthenticationChanged;
        authCheckTimer?.Dispose();
        return ValueTask.CompletedTask;
    }
}