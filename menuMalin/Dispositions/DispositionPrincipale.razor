@inherits LayoutComponentBase
@using System
@inject NavigationManager Navigation
@inject IServiceAuthentification AuthService
@implements IAsyncDisposable

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm border-bottom">
    <div class="container">
        @* --- LOGO --- *@
        <a class="navbar-brand d-flex align-items-center fw-bold" href="">
            <img src="images/logo.png" alt="Logo" width="35" height="35" class="me-2 logo-circle">
            <span style="color: #2d6a4f;">MenuMalin</span>
        </a>

        @* --- BOUTON HAMBURGER --- *@
        <button class="navbar-toggler" type="button" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        @* --- CONTENU DU MENU --- *@
        <div class="@NavMenuCssClass navbar-collapse" id="navbarNavMenu">
            
            <ul class="navbar-nav mx-auto text-center">
                <li class="nav-item">
                    <NavLink class="nav-link px-3" href="" Match="NavLinkMatch.All">Accueil</NavLink>
                </li>
                @if (isAuthenticated)
                {
                    <li class="nav-item">
                        <NavLink class="nav-link px-3" href="my-recipes">Mes Favoris</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link px-3" href="my-created-recipes">Mes Recettes</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link px-3" href="create-recipe">Créer une Recette</NavLink>
                    </li>
                }
                @if (isAuthenticated)
                {
                    <li class="nav-item">
                        <NavLink class="nav-link px-3" href="public-recipes">Recettes Partagées</NavLink>
                    </li>
                }
                <li class="nav-item">
                    <NavLink class="nav-link px-3" href="contact">Nous contacter</NavLink>
                </li>
            </ul>

            @* AUTHENTIFICATION *@
            <div class="d-flex flex-column flex-lg-row align-items-center justify-content-center">
                @if (isAuthenticated)
                {
                    <div class="dropdown">
                        <button class="btn btn-sm btn-light dropdown-toggle border-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle me-1"></i> @currentUser?.Name
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 text-center text-lg-start">
                            <li>
                                <button class="dropdown-item text-danger" @onclick="Logout">
                                    <i class="bi bi-box-arrow-right me-2"></i>Déconnexion
                                </button>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <button class="btn btn-sm btn-link text-decoration-none text-muted mb-2 mb-lg-0 me-lg-2" @onclick="Login">
                        Connexion
                    </button>
                    <button class="btn btn-sm btn-success px-4 shadow-sm fw-bold" @onclick="Register">
                        Créer un compte
                    </button>
                }
            </div>
        </div>
    </div>
</nav>

<main>
    @Body
</main>

@code {
    private bool collapseNavMenu = true;
    private bool isAuthenticated = false;
    private UtilisateurAuth? currentUser;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;
        await CheckAuthentication();
    }

    private async Task CheckAuthentication()
    {
        try
        {
            currentUser = await AuthService.GetCurrentUserAsync();
            isAuthenticated = currentUser?.IsAuthenticated ?? false;
        }
        catch
        {
            isAuthenticated = false;
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        collapseNavMenu = true;
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void Login()
    {
        Navigation.NavigateTo("/login");
    }

    private void Register()
    {
        Navigation.NavigateTo("/register");
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
    }

    ValueTask IAsyncDisposable.DisposeAsync()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        return ValueTask.CompletedTask;
    }
}