<ErrorBoundary>
    <ChildContent>
        <Router AppAssembly="@typeof(App).Assembly">
            <Found Context="routeData">
                <RouteView RouteData="@routeData" DefaultLayout="@typeof(DispositionPrincipale)" />
                <FocusOnNavigate RouteData="@routeData" Selector="h1"/>
            </Found>
            <NotFound>
                <PageTitle>Non trouvé</PageTitle>
                <LayoutView Layout="@typeof(DispositionPrincipale)">
                    <p role="alert">Désolé, rien à cette adresse.</p>
                </LayoutView>
            </NotFound>
        </Router>
    </ChildContent>
    <ErrorContent Context="ex">
        <div class="container mt-5 text-center">
            <div class="alert alert-danger">
                <h2><i class="bi bi-exclamation-circle me-2"></i>Une erreur inattendue s'est produite</h2>
                <p class="text-muted">Rechargez la page ou contactez le support.</p>
                <a href="/" class="btn btn-success">Retour à l'accueil</a>
            </div>
        </div>
    </ErrorContent>
</ErrorBoundary>
