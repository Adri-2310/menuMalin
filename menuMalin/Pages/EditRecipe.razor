@page "/edit-recipe/{RecipeId}"
@using menuMalin.Services
@using menuMalin.Shared.Models.Dtos
@using menuMalin.Shared.Models.Requests
@inject IUserRecipeService UserRecipeService
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

<PageTitle>MenuMalin - Modifier Recette</PageTitle>

@if (isLoading)
{
    <div class="container mt-5">
        <div class="text-center py-5">
            <div class="spinner-border text-success"></div>
            <p class="mt-2 text-muted">Chargement de la recette...</p>
        </div>
    </div>
}
else if (recipe == null)
{
    <div class="container mt-5">
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Recette non trouvée</h4>
            <p>Cette recette n'existe pas ou vous n'avez pas accès à celle-ci.</p>
            <a href="/my-created-recipes" class="btn btn-primary">Retour à mes recettes</a>
        </div>
    </div>
}
else
{
    <div class="container mt-4 mb-5">
        <button class="btn btn-link text-dark text-decoration-none mb-4 ps-0" @onclick="GoBack">
            <i class="bi bi-arrow-left me-2"></i>Retour
        </button>

        <div class="row">
            <div class="col-lg-8">
                <h1 class="mb-4">Modifier la recette</h1>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        @errorMessage
                        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
                    </div>
                }

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i>
                        @successMessage
                        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
                    </div>
                }

                <div class="card shadow-sm mb-4">
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Titre</label>
                            <input type="text" class="form-control" @bind="recipe.Title" />
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Catégorie</label>
                                <input type="text" class="form-control" @bind="recipe.Category" placeholder="Ex: Dessert, Plat principal..." />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Pays / Région</label>
                                <input type="text" class="form-control" @bind="recipe.Area" placeholder="Ex: Français, Italien..." />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Instructions</label>
                            <textarea class="form-control" rows="6" @bind="recipe.Instructions"></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Ingrédients</label>
                            <div class="card border-light bg-light rounded-3 p-3">
                                @if (recipe.Ingredients == null || recipe.Ingredients.Count == 0)
                                {
                                    <p class="text-muted mb-3"><i class="bi bi-info-circle me-2"></i>Aucun ingrédient ajouté. Cliquez sur "Ajouter" pour commencer.</p>
                                }
                                else
                                {
                                    @foreach (var (ingredient, index) in recipe.Ingredients.Select((item, i) => (item, i)))
                                    {
                                        <div class="input-group mb-2">
                                            <input
                                                type="text"
                                                class="form-control shadow-sm rounded-start-3"
                                                placeholder="Ex: 200g farine"
                                                @bind="recipe.Ingredients[index]" />
                                            <button
                                                type="button"
                                                class="btn btn-outline-danger rounded-end-3"
                                                @onclick="() => RemoveIngredient(index)"
                                                title="Supprimer cet ingrédient">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </div>
                                    }
                                }
                                <button
                                    type="button"
                                    class="btn btn-outline-success btn-sm rounded-pill mt-2"
                                    @onclick="AddIngredient">
                                    <i class="bi bi-plus-circle me-1"></i>Ajouter un ingrédient
                                </button>
                            </div>
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" @bind="recipe.IsPublic" id="isPublic">
                            <label class="form-check-label" for="isPublic">
                                Rendre cette recette publique (visible à la communauté)
                            </label>
                        </div>

                        <div class="d-flex gap-2">
                            <button class="btn btn-primary" @onclick="SaveRecipe" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                Enregistrer
                            </button>
                            <button class="btn btn-outline-secondary" @onclick="GoBack">Annuler</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm sticky-top" style="top: 20px;">
                    <div class="card-body">
                        <h5 class="card-title">Aperçu</h5>
                        @if (!string.IsNullOrEmpty(recipe.ImageUrl))
                        {
                            <img src="@recipe.ImageUrl" alt="@recipe.Title" class="img-fluid rounded mb-3" />
                        }
                        else
                        {
                            <div class="bg-light rounded p-4 text-center mb-3">
                                <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                            </div>
                        }
                        <h6>@recipe.Title</h6>
                        <p class="text-muted small">
                            @if (!string.IsNullOrEmpty(recipe.Category))
                            {
                                <span class="badge bg-info">@recipe.Category</span>
                            }
                            @if (!string.IsNullOrEmpty(recipe.Area))
                            {
                                <span class="badge bg-secondary">@recipe.Area</span>
                            }
                        </p>
                        <p class="text-muted small">Créée le: @recipe.CreatedAt.ToString("dd/MM/yyyy")</p>
                    </div>
                </div>

                <div class="card border-2 border-danger mt-4 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-exclamation-diamond text-danger me-2" style="font-size: 1.5rem;"></i>
                            <h5 class="card-title mb-0 text-danger fw-bold">Zone de danger</h5>
                        </div>
                        <p class="text-muted small mb-3">Supprimer cette recette est une action <strong>irréversible</strong>. L'image et toutes les données seront supprimées.</p>
                        <button class="btn btn-danger btn-sm w-100 rounded-3" @onclick="ConfirmDelete" disabled="@isSaving">
                            <i class="bi bi-trash-fill me-2"></i>Supprimer définitivement
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string? RecipeId { get; set; }

    private UserRecipeDto? recipe;
    private bool isLoading = true;
    private bool isSaving = false;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecipe();
    }

    private async Task LoadRecipe()
    {
        try
        {
            isLoading = true;
            if (string.IsNullOrEmpty(RecipeId))
            {
                errorMessage = "ID de recette manquant";
                return;
            }

            recipe = await UserRecipeService.GetByIdAsync(RecipeId);
            if (recipe == null)
            {
                errorMessage = "Recette non trouvée";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveRecipe()
    {
        try
        {
            isSaving = true;
            errorMessage = null;
            successMessage = null;

            if (recipe == null || string.IsNullOrWhiteSpace(recipe.Title))
            {
                errorMessage = "Le titre est obligatoire";
                return;
            }

            if (string.IsNullOrWhiteSpace(recipe.Instructions))
            {
                errorMessage = "Les instructions sont obligatoires";
                return;
            }

            // Créer une requête de mise à jour
            var request = new CreateUserRecipeRequest
            {
                Title = recipe.Title,
                Category = recipe.Category,
                Area = recipe.Area,
                Instructions = recipe.Instructions,
                ImageUrl = recipe.ImageUrl,
                IsPublic = recipe.IsPublic,
                Ingredients = recipe.Ingredients ?? new List<string>()
            };

            // Mettre à jour la recette
            var result = await UserRecipeService.UpdateAsync(recipe.UserRecipeId, request);

            if (result != null)
            {
                successMessage = "Recette mise à jour avec succès";
                await Task.Delay(1500);
                Nav.NavigateTo("/my-created-recipes");
            }
            else
            {
                errorMessage = "Erreur lors de la mise à jour";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ConfirmDelete()
    {
        if (recipe == null)
            return;

        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            "Êtes-vous sûr de vouloir supprimer cette recette ? Cette action est irréversible.");

        if (confirmed)
        {
            await DeleteRecipe();
        }
    }

    private async Task DeleteRecipe()
    {
        try
        {
            isSaving = true;
            errorMessage = null;

            if (recipe == null)
                return;

            bool result = await UserRecipeService.DeleteAsync(recipe.UserRecipeId);

            if (result)
            {
                successMessage = "Recette supprimée avec succès";
                await Task.Delay(1500);
                Nav.NavigateTo("/my-created-recipes");
            }
            else
            {
                errorMessage = "Erreur lors de la suppression. Veuillez réessayer.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void AddIngredient()
    {
        if (recipe?.Ingredients != null)
        {
            recipe.Ingredients.Add("");
        }
    }

    private void RemoveIngredient(int index)
    {
        if (recipe?.Ingredients != null && index >= 0 && index < recipe.Ingredients.Count)
        {
            recipe.Ingredients.RemoveAt(index);
        }
    }

    private void GoBack() => Nav.NavigateTo("/my-created-recipes");
}
