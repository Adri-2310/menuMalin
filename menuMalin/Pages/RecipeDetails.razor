

@page "/recipe/{Id}"
@using menuMalin.Models
@using menuMalin.Services
@inject IRecipeService RecipeService
@inject NavigationManager Nav

<div class="container mt-4 mb-5">
    @if (recipe == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-success"></div>
            <p class="mt-2">Mijotage en cours...</p>
        </div>
    }
    else
    {
        <div class="row">
            @* Colonne Image *@
            <div class="col-md-5 mb-4">
                <div class="position-sticky top-0" style="z-index: 0;">
                    <img src="@recipe.StrMealThumb" class="img-fluid rounded-4 shadow w-100" alt="@recipe.StrMeal">
                    <div class="mt-3 d-flex gap-2">
                        <span class="badge bg-success px-3 py-2">@recipe.StrCategory</span>
                        <span class="badge bg-secondary px-3 py-2">@recipe.StrArea</span>
                    </div>
                </div>
            </div>

            @* Colonne Infos *@
            <div class="col-md-7">
                <h1 class="display-5 fw-bold mb-3">@recipe.StrMeal</h1>
                
                <div class="card border-0 shadow-sm bg-light mb-4">
                    <div class="card-body">
                        <h4 class="fw-bold"><i class="bi bi-card-text me-2"></i>Instructions</h4>
                        <p class="card-text" style="white-space: pre-line;">@recipe.StrInstructions</p>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-outline-danger btn-lg rounded-pill px-4">
                        <i class="bi bi-heart"></i> Favori
                    </button>
                    <a href="/" class="btn btn-outline-dark btn-lg rounded-pill px-4">
                        Retour
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string Id { get; set; }
    private Recipe? recipe;

    protected override async Task OnParametersSetAsync()
    {
        // On charge la recette dès que l'ID change
        recipe = await RecipeService.GetRecipeByIdAsync(Id);
    }
}