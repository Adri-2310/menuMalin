@page "/favorites"
@using menuMalin.Services
@using menuMalin.Composants.Recette
@using menuMalin.Shared.Modeles.DTOs
@inject IServiceFavorisFrontend FavoriteService
@inject IServiceAuthentification AuthService
@inject NavigationManager Nav

<PageTitle>Mes Favoris - MenuMalin</PageTitle>

@if (isCheckingAuth)
{
    <div class="text-center py-5">
        <div class="spinner-border text-success" role="status"></div>
        <p class="mt-2 text-muted">Vérification de l'authentification...</p>
    </div>
}
else if (!isAuthenticated)
{
    <div class="container mt-4 mb-5">
        <div class="alert alert-warning text-center rounded-4 py-5" role="alert">
            <i class="bi bi-lock-fill me-2" style="font-size: 2rem;"></i>
            <h3 class="mt-3">Accès réservé</h3>
            <p class="text-muted mb-4">Vous devez être connecté pour voir vos favoris.</p>
            <a href="/" class="btn btn-success btn-lg rounded-pill px-5">Se connecter</a>
        </div>
    </div>
}
else
{
    <div class="container mt-4 animate-fade-in">
        <div class="d-flex align-items-center mb-4">
            <i class="bi bi-heart-fill text-danger fs-3 me-3"></i>
            <h2 class="fw-bold mb-0">Mes Recettes Favorites</h2>
        </div>

        @if (favorites == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-success" role="status"></div>
                <p class="mt-2 text-muted">Chargement de vos favoris...</p>
            </div>
        }
        else if (!favorites.Any())
        {
            <div class="text-center py-5 bg-light rounded-4">
                <i class="bi bi-basket display-1 text-muted opacity-50"></i>
                <h3 class="mt-3 text-muted">Aucun favori pour l'instant</h3>
                <p>Explorez les recettes et cliquez sur le cœur !</p>
                <a href="/" class="btn btn-success rounded-pill px-4">Découvrir des recettes</a>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-3 g-4">
                @foreach (var recipe in favorites)
                {
                    <div class="col">
                        <CarteRecette RecipeId="@recipe.RecipeId"
                                             MealDBId="@recipe.MealDBId"
                                             Title="@recipe.Title"
                                             ImageUrl="@recipe.ImageUrl"
                                             Category="@recipe.Category" />
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private List<RecetteDTO>? favorites;
    private bool isAuthenticated = false;
    private bool isCheckingAuth = true;

    protected override async Task OnInitializedAsync()
    {
        await CheckAuthentication();
        if (isAuthenticated)
        {
            await LoadFavorites();
        }
    }

    // OnAfterRenderAsync removed: polling infini à toutes les 2 secondes
    // Les favoris se chargeront au OnInitializedAsync et lors du retour à la page

    private async Task CheckAuthentication()
    {
        try
        {
            var user = await AuthService.GetCurrentUserAsync();
            isAuthenticated = user?.IsAuthenticated ?? false;
        }
        catch
        {
            isAuthenticated = false;
        }
        finally
        {
            isCheckingAuth = false;
        }
    }

    private async Task LoadFavorites()
    {
        try
        {
            favorites = await FavoriteService.GetUserFavoritesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement des favoris: {ex.Message}");
            favorites = new List<RecetteDTO>();
        }
    }
}