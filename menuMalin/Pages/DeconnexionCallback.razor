@page "/authentication/logout-callback"
@inject NavigationManager Nav

<div class="container mt-5 animate-fade-in text-center">
    <div class="card border-0 shadow-sm rounded-4 p-5 bg-light">
        <div class="display-1 mb-4">👋</div>
        <h2 class="fw-bold">À bientôt dans MenuMalin !</h2>
        <p class="text-muted">Vous avez été déconnecté avec succès.</p>
        <hr class="my-4 mx-auto" style="width: 50px;">
        <button class="btn btn-success rounded-pill px-4" @onclick="GoHome">
            Retourner à l'accueil
        </button>
    </div>
</div>

@code {
    private void GoHome() => Nav.NavigateTo("/");
}