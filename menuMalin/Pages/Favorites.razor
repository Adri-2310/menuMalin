
@page "/favorites"
@using Microsoft.AspNetCore.Components.Authorization
@using menuMalin.Models
@using menuMalin.Services
@using menuMalin.Components.Recipe
@attribute [Authorize] 
@inject IFavoriteService FavoriteService

    <PageTitle>Mes Favoris - MenuMalin</PageTitle>

    <div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
    <i class="bi bi-heart-fill text-danger fs-3 me-3"></i>
    <h2 class="fw-bold mb-0">Mes Recettes Favorites</h2>
    </div>

    @if (favorites == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-success" role="status"></div>
        </div>
}
else if (!favorites.Any())
{
    <div class="text-center py-5 bg-light rounded-4">
        <i class="bi bi-basket display-1 text-muted opacity-50"></i>
        <h3 class="mt-3 text-muted">Aucun favori pour l'instant</h3>
        <p>Explorez les recettes et cliquez sur le cœur !</p>
        <a href="/" class="btn btn-success rounded-pill px-4">Découvrir des recettes</a>
        </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var recipe in favorites)
    {
        <div class="col">
            <RecipeCard Recipe="recipe" />
            </div>
    }
    </div>
}
</div>

    @code {
private List<Recipe>? favorites;

protected override async Task OnInitializedAsync()
{
    favorites = await FavoriteService.GetFavoritesAsync();
}
}