@page "/search"
@using Microsoft.AspNetCore.Authorization
@using menuMalin.Models
@using menuMalin.Services
@using menuMalin.Components.Recipe
@attribute [Authorize]
@inject IRecipeService RecipeService
@inject NavigationManager Nav

<PageTitle>MenuMalin - Recherche</PageTitle>

<div class="container mt-4 mb-5 animate-fade-in">
    @* Bouton Retour *@
    <button class="btn btn-link text-dark text-decoration-none mb-4 ps-0" @onclick="GoBack">
        <i class="bi bi-arrow-left me-2"></i>Retour à l'accueil
    </button>

    @* Titre Section *@
    <div class="mb-4">
        <h1 class="display-5 fw-bold mb-2">Explorer les recettes</h1>
        <p class="text-muted">Utilisez les filtres ci-dessous pour trouver votre recette idéale</p>
    </div>

    @* SECTION FILTRES *@
    <div class="row mb-5">
        <div class="col-md-4 mb-3">
            <label class="form-label fw-bold">Recherche texte</label>
            <div class="input-group input-group-lg shadow-sm rounded-pill overflow-hidden bg-white border">
                <span class="input-group-text bg-white border-0 ps-4">
                    <i class="bi bi-search text-success"></i>
                </span>
                <input type="text"
                       class="form-control border-0 shadow-none py-3"
                       placeholder="Taper un ingrédient..."
                       @bind="searchTerm"
                       @bind:event="oninput"
                       @onkeyup="HandleKeyUp" />
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label fw-bold">Catégorie</label>
            <select class="form-select form-select-lg shadow-sm rounded-pill" @bind="selectedCategory" @bind:after="ClearSearchError">
                <option value="">-- Toutes les catégories --</option>
                @foreach (var cat in categories)
                {
                    <option value="@cat">@cat</option>
                }
            </select>
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label fw-bold">Zone/Cuisine</label>
            <select class="form-select form-select-lg shadow-sm rounded-pill" @bind="selectedArea" @bind:after="ClearSearchError">
                <option value="">-- Toutes les zones --</option>
                @foreach (var area in areas)
                {
                    <option value="@area">@area</option>
                }
            </select>
        </div>
    </div>

    @* BOUTONS D'ACTION *@
    <div class="d-flex gap-2 mb-5">
        <button class="btn btn-success btn-lg rounded-pill px-5 fw-bold" @onclick="ApplyFilters">
            <i class="bi bi-search me-2"></i>Rechercher
        </button>
        <button class="btn btn-outline-success btn-lg rounded-pill px-5 fw-bold" @onclick="ResetFilters">
            <i class="bi bi-arrow-clockwise me-2"></i>Réinitialiser
        </button>
    </div>

    @* GESTION D'ÉTAT *@
    @if (!string.IsNullOrEmpty(filterError))
    {
        <div class="alert alert-warning alert-dismissible fade show rounded-4" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>
            <strong>Attention !</strong> @filterError
            <button type="button" class="btn-close" @onclick="() => filterError = null"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-success"></div>
            <p class="mt-2 text-muted">Chargement des recettes...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(searchError))
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>Erreur !</strong> @searchError
            <button type="button" class="btn-close" @onclick="() => searchError = null"></button>
        </div>
    }
    else if (recipes == null)
    {
        <div class="alert alert-info text-center rounded-4 py-5" role="alert">
            <i class="bi bi-search me-2"></i>
            <h5>Prêt à explorer ?</h5>
            <p class="text-muted mb-0">Entrez un terme de recherche ou choisissez un filtre pour commencer</p>
        </div>
    }
    else if (recipes != null && recipes.Count == 0)
    {
        <div class="alert alert-warning text-center rounded-4 py-5" role="alert">
            <i class="bi bi-inbox me-2"></i>
            <h5>Aucun résultat trouvé</h5>
            <p class="text-muted mb-0">Essayez d'ajuster vos critères de recherche</p>
        </div>
    }
    else if (recipes != null && recipes.Count > 0)
    {
        <RecipeGrid Recipes="recipes" />
    }
</div>

@code {
    private string searchTerm = "";
    private string selectedCategory = "";
    private string selectedArea = "";
    private List<string> categories = new();
    private List<string> areas = new();
    private List<Recipe>? recipes;
    private bool isLoading = false;
    private string? searchError;
    private string? filterError;

    protected override async Task OnInitializedAsync()
    {
        await LoadFilterOptions();
    }

    private async Task LoadFilterOptions()
    {
        try
        {
            filterError = null;
            categories = await RecipeService.GetCategoriesAsync();
            areas = await RecipeService.GetAreasAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement des filtres: {ex.Message}");
            filterError = "Impossible de charger les filtres. Veuillez réessayer.";
        }
    }

    private async Task ApplyFilters()
    {
        if (string.IsNullOrWhiteSpace(searchTerm) &&
            string.IsNullOrWhiteSpace(selectedCategory) &&
            string.IsNullOrWhiteSpace(selectedArea))
        {
            recipes = new List<Recipe>();
            return;
        }

        try
        {
            isLoading = true;
            searchError = null;
            recipes = null;

            @* Priorité: si recherche texte → chercher par texte
                 Sinon: filtrer par catégorie ou zone *@
            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                recipes = await RecipeService.SearchRecipesAsync(searchTerm);
            }
            else if (!string.IsNullOrWhiteSpace(selectedCategory))
            {
                recipes = await RecipeService.SearchByCategoryAsync(selectedCategory);
            }
            else if (!string.IsNullOrWhiteSpace(selectedArea))
            {
                recipes = await RecipeService.SearchByAreaAsync(selectedArea);
            }

            if (recipes == null || !recipes.Any())
            {
                recipes = new List<Recipe>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors de la recherche: {ex.Message}");
            searchError = "Erreur lors de la recherche. Veuillez réessayer.";
            recipes = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ResetFilters()
    {
        searchTerm = "";
        selectedCategory = "";
        selectedArea = "";
        recipes = null;
        searchError = null;
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ApplyFilters();
        }
    }

    private void ClearSearchError()
    {
        // Efface le message d'erreur quand l'utilisateur change un filtre
        searchError = null;
    }

    private void GoBack() => Nav.NavigateTo("/");
}
