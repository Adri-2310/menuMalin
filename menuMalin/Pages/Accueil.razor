@page "/"
@using menuMalin.Modeles
@using menuMalin.Services
@using menuMalin.Composants.Recette
@inject IServiceRecette RecipeService
@inject IServiceAuthentification AuthService
@inject ServiceEtatAuthentification AuthState
@inject NavigationManager Nav

<PageTitle>MenuMalin - Accueil</PageTitle>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-success"></div>
        <p class="mt-2 text-muted">Chargement...</p>
    </div>
}
else if (isAuthenticated)
{
    <div class="container mt-4 animate-fade-in">
        <div class="welcome-card p-5 mb-5 rounded-4 shadow-sm position-relative overflow-hidden">
            <div class="bg-pattern"></div>

            <div class="row align-items-center position-relative">
                <div class="col-md-8">
                    <span class="badge bg-success-light text-success mb-2 px-3">Espace Membre</span>
                    <h1 class="display-5 fw-bold text-dark">Ravi de vous revoir, <span class="text-success">@currentUser?.Name</span> ! 👋</h1>
                    <p class="fs-5 text-muted mb-4">Vos menus personnalisés et vos listes de courses sont à jour.</p>
                    <div class="d-flex flex-wrap gap-3">
                        <a href="favorites" class="btn btn-success btn-lg px-4 rounded-pill shadow-sm hover-scale">
                            <i class="bi bi-heart-fill me-2"></i>Mes Favoris
                        </a>
                        <button @onclick="Logout" class="btn btn-outline-danger btn-lg px-4 rounded-pill hover-scale">
                            <i class="bi bi-box-arrow-right me-2"></i>Se déconnecter
                        </button>
                    </div>
                </div>
                <div class="col-md-4 text-center d-none d-md-block">
                    <div class="icon-blob mx-auto">
                        <i class="bi bi-egg-fried text-success"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="recipe-section">
            @* ajout de la barre de recherche *@
            <BarreRecherche OnSearch="HandleSearch"></BarreRecherche>

            <div class="d-flex justify-content-between align-items-end mb-4">
                <div>
                    <h2 class="fw-bold mb-0">Inspirations du jour</h2>
                    <p class="text-muted mb-0">Découvrez de nouvelles recettes basées sur vos goûts.</p>
                </div>
                @if (featuredRecipes != null)
                {
                    <button class="btn btn-sm btn-link text-success fw-bold text-decoration-none hover-underline" @onclick="ExploreAll">
                        Tout explorer <i class="bi bi-arrow-right"></i>
                    </button>
                }
            </div>

            @* GESTION DE L'ÉTAT D'AFFICHAGE *@
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger shadow-sm rounded-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Oups !</strong> Impossible de charger les recettes : @errorMessage
                </div>
            }
            else if (featuredRecipes == null)
            {
                @* SKELETON LOADING *@
                <div class="row row-cols-1 row-cols-md-3 g-4">
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="col">
                            <div class="card border-0 shadow-sm rounded-4 h-100 skeleton-card">
                                <div class="card-body text-center py-5">
                                    <div class="spinner-border text-success opacity-50" role="status"></div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                @* VRAIES RECETTES *@
                <GrilleRecettes Recipes="featuredRecipes" />
            }
        </div>
    </div>
}
else
{
    @* --- SECTION VISITEUR --- *@
    <div class="hero-gradient text-white py-5 mb-5 shadow-sm position-relative">
        <div class="container py-5 text-center position-relative">
            <div class="badge-float mb-3">
                <span class="badge rounded-pill bg-white text-success px-4 py-2 fw-bold shadow">
                    ✨ 100% GRATUIT
                </span>
            </div>
            <h1 class="display-1 fw-black mb-3 floating">MenuMalin</h1>
            <p class="lead mb-5 px-md-5 mx-auto text-light opacity-90" style="max-width: 800px;">
                L'assistant culinaire intelligent qui transforme vos envies en listes de courses.
            </p>
            <div class="d-flex justify-content-center gap-3">
                <button @onclick="Login" class="btn btn-light btn-lg text-success fw-bold px-5 rounded-pill shadow-lg hover-lift">
                    C'est parti !
                </button>
            </div>
        </div>
        <div class="custom-shape-divider-bottom">
            <svg viewBox="0 0 1200 120" preserveAspectRatio="none">
                <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V0C0,0,10.79,12.09,47.19,23.58c31.1,9.81,67,10.51,96.5,10.51,33.1,0,67.5-6.5,102.3-15.51" fill="#ffffff"></path>
            </svg>
        </div>
    </div>

    <div class="container pt-4">
        <div class="row g-5 py-5">
            <div class="col-lg-4 text-center">
                <div class="feature-box p-4 rounded-4 shadow-hover transition">
                    <div class="icon-circle bg-success-soft text-success mb-4">
                        <i class="bi bi-search"></i>
                    </div>
                    <h4 class="fw-bold">Recherche API</h4>
                    <p class="text-muted">Explorez des milliers de recettes internationales via <strong>TheMealDB</strong>.</p>
                </div>
            </div>
            <div class="col-lg-4 text-center">
                <div class="feature-box p-4 rounded-4 shadow-hover transition">
                    <div class="icon-circle bg-danger-soft text-danger mb-4">
                        <i class="bi bi-pencil-square"></i>
                    </div>
                    <h4 class="fw-bold">Modifs Locales</h4>
                    <p class="text-muted">Ajustez les doses et les étapes. Vos secrets de cuisine restent les vôtres.</p>
                </div>
            </div>
            <div class="col-lg-4 text-center">
                <div class="feature-box p-4 rounded-4 shadow-hover transition">
                    <div class="icon-circle bg-primary-soft text-primary mb-4">
                        <i class="bi bi-list-check"></i>
                    </div>
                    <h4 class="fw-bold">Courses Pro</h4>
                    <p class="text-muted">Générez une liste claire pour ne plus rien oublier au supermarché.</p>
                </div>
            </div>
        </div>
    </div>
    <div class="container pb-5">
        <div class="info-banner d-flex align-items-center p-4 rounded-4 bg-light border-0 shadow-sm">
            <div class="fs-1 me-4">🔐</div>
            <div>
                <h5 class="fw-bold mb-1">Confidentialité totale</h5>
                <p class="mb-0 text-muted small">
                    Aucune donnée n'est revendue. Vos favoris sont stockés localement sur votre navigateur grâce au LocalStorage.
                </p>
            </div>
        </div>
    </div>
}

<ModaleRecette Recipe="selectedRecipe" OnClose="@(() => selectedRecipe = null)" />

@code {
    private List<Recette>? featuredRecipes;
    private string? errorMessage;
    private Recette? selectedRecipe;
    private bool isLoading = true;
    private bool isAuthenticated = false;
    private UtilisateurAuth? currentUser;

    protected override async Task OnInitializedAsync()
    {
        // Charger l'état d'authentification depuis localStorage avant de vérifier
        await AuthState.InitializeAuthStateAsync();
        await CheckAuthentication();
        if (isAuthenticated)
        {
            await LoadDefaultRecipes();
        }
    }

    private async Task CheckAuthentication()
    {
        try
        {
            // Vérifier d'abord l'état global (Singleton)
            if (AuthState?.CurrentUser != null && AuthState.IsAuthenticated)
            {
                currentUser = AuthState.CurrentUser;
                isAuthenticated = true;
            }
            else
            {
                // Sinon appeler l'API
                currentUser = await AuthService.GetCurrentUserAsync();
                isAuthenticated = currentUser?.IsAuthenticated ?? false;
            }
        }
        catch
        {
            isAuthenticated = false;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadDefaultRecipes()
    {
        isLoading = true;
        try
        {
            featuredRecipes = await RecipeService.GetRandomRecipesAsync(3);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSearch(string query)
    {
        try
        {
            errorMessage = null;
            featuredRecipes = null;
            featuredRecipes = await RecipeService.SearchRecipesAsync(query);
            if (featuredRecipes == null || !featuredRecipes.Any())
            {
                errorMessage = $"Aucune recette trouvée pour '{query}'.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur lors de la recherche.";
        }
    }

    private void ExploreAll()
    {
        Nav.NavigateTo("/recherche");
    }

    private void Login()
    {
        Nav.NavigateTo("/connexion");
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
    }
}
