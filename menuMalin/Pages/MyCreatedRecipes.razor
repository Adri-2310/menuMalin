@page "/my-created-recipes"
@using Microsoft.AspNetCore.Components.Authorization
@using menuMalin.Services
@using menuMalin.Shared.Models.Dtos
@attribute [Authorize]
@inject IUserRecipeService UserRecipeService
@inject NavigationManager Nav

<PageTitle>MenuMalin - Mes Recettes Créées</PageTitle>

<div class="container mt-4 mb-5 animate-fade-in">
    @* Bouton Retour *@
    <button class="btn btn-link text-dark text-decoration-none mb-4 ps-0" @onclick="GoBack">
        <i class="bi bi-arrow-left me-2"></i>Retour à l'accueil
    </button>

    @* Titre Section *@
    <div class="d-flex align-items-center justify-content-between mb-5">
        <div>
            <h1 class="display-5 fw-bold mb-2">🍳 Mes Recettes Créées</h1>
            <p class="text-muted lead">Gérez et partagez vos créations culinaires</p>
        </div>
        <a href="/create-recipe" class="btn btn-success btn-lg rounded-pill">
            <i class="bi bi-plus-circle me-2"></i>Ajouter une recette
        </a>
    </div>

    @if (recipes == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-success"></div>
            <p class="mt-2 text-muted">Chargement de vos recettes...</p>
        </div>
    }
    else if (!recipes.Any())
    {
        <div class="text-center py-5 bg-light rounded-4">
            <i class="bi bi-collection display-1 text-muted opacity-50"></i>
            <h3 class="mt-3 text-muted">Vous n'avez pas encore créé de recette</h3>
            <p class="text-muted">Commencez par créer votre première recette!</p>
            <a href="/create-recipe" class="btn btn-success rounded-pill px-4">
                <i class="bi bi-plus-circle me-2"></i>Créer une recette
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Titre</th>
                        <th>Catégorie</th>
                        <th>Statut</th>
                        <th>Créée le</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var recipe in recipes)
                    {
                        <tr>
                            <td>
                                <strong>@recipe.Title</strong>
                                @if (!string.IsNullOrEmpty(recipe.Area))
                                {
                                    <br />
                                    <small class="text-muted">@recipe.Area</small>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(recipe.Category))
                                {
                                    <span class="badge bg-info rounded-pill">@recipe.Category</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (recipe.IsPublic)
                                {
                                    <span class="badge bg-success rounded-pill">
                                        <i class="bi bi-globe me-1"></i>Public
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary rounded-pill">
                                        <i class="bi bi-lock me-1"></i>Privé
                                    </span>
                                }
                            </td>
                            <td>
                                <small class="text-muted">@recipe.CreatedAt.ToString("dd/MM/yyyy")</small>
                            </td>
                            <td class="text-end">
                                <button
                                    class="btn btn-sm btn-outline-primary rounded-pill me-2"
                                    @onclick="() => ToggleVisibility(recipe.UserRecipeId, recipe.IsPublic)"
                                    title="@(recipe.IsPublic ? "Rendre privé" : "Rendre public")"
                                    disabled="@isUpdating">
                                    <i class="bi @(recipe.IsPublic ? "bi-lock" : "bi-globe") me-1"></i>
                                    @(recipe.IsPublic ? "Priver" : "Publier")
                                </button>
                                <button
                                    class="btn btn-sm btn-outline-danger rounded-pill"
                                    @onclick="() => DeleteRecipe(recipe.UserRecipeId)"
                                    title="Supprimer cette recette"
                                    disabled="@isUpdating">
                                    <i class="bi bi-trash me-1"></i>Supprimer
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Messages d'erreur/succès *@
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show rounded-4 mt-3" role="alert">
                <i class="bi bi-check-circle me-2"></i>
                <strong>Succès !</strong> @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show rounded-4 mt-3" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>Erreur !</strong> @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }
    }
</div>

@code {
    private List<UserRecipeDto>? recipes;
    private bool isUpdating = false;
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecipes();
    }

    private async Task LoadRecipes()
    {
        try
        {
            recipes = await UserRecipeService.GetMyRecipesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement : {ex.Message}";
            Console.WriteLine($"Erreur: {ex}");
        }
    }

    private async Task ToggleVisibility(string recipeId, bool currentlyPublic)
    {
        try
        {
            isUpdating = true;
            errorMessage = null;
            successMessage = null;

            bool newIsPublic = !currentlyPublic;
            bool result = await UserRecipeService.UpdateVisibilityAsync(recipeId, newIsPublic);

            if (result)
            {
                // Mettre à jour la liste locale
                var recipe = recipes?.FirstOrDefault(r => r.UserRecipeId == recipeId);
                if (recipe != null)
                {
                    recipe.IsPublic = newIsPublic;
                    successMessage = $"La recette est maintenant {(newIsPublic ? "publique" : "privée")}";
                }
            }
            else
            {
                errorMessage = "Erreur lors de la mise à jour. Veuillez réessayer.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
            Console.WriteLine($"Erreur: {ex}");
        }
        finally
        {
            isUpdating = false;
        }
    }

    private async Task DeleteRecipe(string recipeId)
    {
        try
        {
            // Confirmation avant suppression
            if (!await ConfirmDelete())
                return;

            isUpdating = true;
            errorMessage = null;
            successMessage = null;

            bool result = await UserRecipeService.DeleteAsync(recipeId);

            if (result)
            {
                // Retirer la recette de la liste
                recipes?.RemoveAll(r => r.UserRecipeId == recipeId);
                successMessage = "La recette a été supprimée avec succès";
            }
            else
            {
                errorMessage = "Erreur lors de la suppression. Veuillez réessayer.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
            Console.WriteLine($"Erreur: {ex}");
        }
        finally
        {
            isUpdating = false;
        }
    }

    private async Task<bool> ConfirmDelete()
    {
        return await JSRuntime.InvokeAsync<bool>("confirm", "Êtes-vous sûr de vouloir supprimer cette recette ? Cette action est irréversible.");
    }

    private void GoBack() => Nav.NavigateTo("/");

    @inject IJSRuntime JSRuntime
}
