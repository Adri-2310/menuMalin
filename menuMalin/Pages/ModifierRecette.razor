@page "/modifier-recette/{RecipeId}"
@using menuMalin.Services
@using menuMalin.DTOs
@using menuMalin.Shared.Modeles.DTOs
@using menuMalin.Shared.Modeles.Requetes
@using Microsoft.AspNetCore.Components.Forms
@inject IServiceRecetteUtilisateur UserRecipeService
@inject IServiceRecette RecipeService
@inject IServiceTeleversement UploadService
@inject IServiceAuthentification AuthService
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

<PageTitle>MenuMalin - Modifier Recette</PageTitle>

@if (isLoading)
{
    <div class="container mt-5">
        <div class="text-center py-5">
            <div class="spinner-border text-success"></div>
            <p class="mt-2 text-muted">Chargement de la recette...</p>
        </div>
    </div>
}
else if (recipe == null)
{
    <div class="container mt-5">
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Recette non trouvée</h4>
            <p>Cette recette n'existe pas ou vous n'avez pas accès à celle-ci.</p>
            <a href="/mes-creations" class="btn btn-primary">Retour à mes recettes</a>
        </div>
    </div>
}
else
{
    <div class="container mt-4 mb-5">
        <button class="btn btn-link text-dark text-decoration-none mb-4 ps-0" @onclick="GoBack">
            <i class="bi bi-arrow-left me-2"></i>Retour
        </button>

        <div class="row">
            <div class="col-lg-8">
                <h1 class="mb-4">Modifier la recette</h1>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        @errorMessage
                        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
                    </div>
                }

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i>
                        @successMessage
                        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
                    </div>
                }

                <div class="card shadow-sm mb-4">
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Titre</label>
                            <input type="text" class="form-control" @bind="recipe.Title" />
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Catégorie</label>
                                <select class="form-select" @bind="recipe.Category">
                                    <option value="">-- Sélectionnez une catégorie --</option>
                                    @foreach (var category in categories)
                                    {
                                        <option value="@category">@category</option>
                                    }
                                </select>
                                @if (isLoadingCategories)
                                {
                                    <small class="text-muted d-block mt-1">
                                        <span class="spinner-border spinner-border-sm me-2"></span>Chargement...
                                    </small>
                                }
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Pays / Région</label>
                                <select class="form-select" @bind="recipe.Area">
                                    <option value="">-- Sélectionnez une région --</option>
                                    @foreach (var area in areas)
                                    {
                                        <option value="@area">@area</option>
                                    }
                                </select>
                                @if (isLoadingAreas)
                                {
                                    <small class="text-muted d-block mt-1">
                                        <span class="spinner-border spinner-border-sm me-2"></span>Chargement...
                                    </small>
                                }
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Instructions</label>
                            <textarea class="form-control" rows="6" @bind="recipe.Instructions"></textarea>
                        </div>

                        @* Image Management *@
                        <div class="mb-4">
                            <label class="form-label fw-bold mb-3">Image de la recette</label>

                            @* Upload d'image *@
                            <div class="mb-3">
                                <label for="imageFile" class="form-label">Choisir une image depuis votre ordinateur</label>
                                <InputFile
                                    class="form-control form-control-lg shadow-sm rounded-3"
                                    id="imageFile"
                                    accept="image/*"
                                    OnChange="HandleImageUpload" />
                                <small class="text-muted d-block">Formats supportés : JPG, PNG, GIF, WebP (max 5MB)</small>
                            </div>

                            @* Aperçu de l'image *@
                            @if (!string.IsNullOrEmpty(recipe?.ImageUrl))
                            {
                                <div class="card border-light bg-light rounded-3 p-3 mb-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div style="position: relative;">
                                            <img
                                                src="@recipe.ImageUrl"
                                                alt="Aperçu"
                                                style="max-height: 150px; max-width: 150px; object-fit: cover; border-radius: 8px;"
                                                @onerror="HandleImageError" />
                                            @if (imageLoadFailed)
                                            {
                                                <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,0,0,0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                    <small class="text-danger fw-bold">Image invalide</small>
                                                </div>
                                            }
                                        </div>
                                        <div>
                                            <p class="mb-2"><strong>Aperçu :</strong></p>
                                            @if (imageLoadFailed)
                                            {
                                                <p class="text-danger small mb-2"><i class="bi bi-exclamation-triangle me-1"></i>L'URL est invalide ou non accessible</p>
                                            }
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ClearImage">
                                                <i class="bi bi-x-circle me-1"></i>Supprimer l'image
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="card border-light bg-light rounded-3 p-5 text-center text-muted mb-3">
                                    <i class="bi bi-image" style="font-size: 2rem;"></i>
                                    <p class="mt-2">Aucune image sélectionnée</p>
                                </div>
                            }

                            @* Option : URL alternative *@
                            <div class="accordion mb-3" id="urlAccordionEdit">
                                <div class="accordion-item border-light">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#urlCollapseEdit">
                                            <i class="bi bi-link-45deg me-2"></i>Ou entrer une URL d'image
                                        </button>
                                    </h2>
                                    <div id="urlCollapseEdit" class="accordion-collapse collapse" data-bs-parent="#urlAccordionEdit">
                                        <div class="accordion-body">
                                            <div class="input-group">
                                                <input
                                                    type="url"
                                                    class="form-control form-control-lg shadow-sm rounded-start-3"
                                                    placeholder="https://example.com/image.jpg"
                                                    @bind="urlInput" />
                                                <button
                                                    type="button"
                                                    class="btn btn-outline-primary rounded-end-3"
                                                    @onclick="() => SetImageFromUrl(urlInput)">
                                                    <i class="bi bi-check-lg me-1"></i>Appliquer
                                                </button>
                                            </div>
                                            <small class="text-muted d-block mt-2">Collez l'URL d'une image publique</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Ingrédients</label>
                            <div class="card border-light bg-light rounded-3 p-3">
                                @if (recipe.Ingredients == null || recipe.Ingredients.Count == 0)
                                {
                                    <p class="text-muted mb-3"><i class="bi bi-info-circle me-2"></i>Aucun ingrédient ajouté. Cliquez sur "Ajouter" pour commencer.</p>
                                }
                                else
                                {
                                    @foreach (var (ingredient, index) in recipe.Ingredients.Select((item, i) => (item, i)))
                                    {
                                        <div class="input-group mb-2">
                                            <input
                                                type="text"
                                                class="form-control shadow-sm rounded-start-3"
                                                placeholder="Ex: 200g farine"
                                                @bind="recipe.Ingredients[index]" />
                                            <button
                                                type="button"
                                                class="btn btn-outline-danger rounded-end-3"
                                                @onclick="() => RemoveIngredient(index)"
                                                title="Supprimer cet ingrédient">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </div>
                                    }
                                }
                                <button
                                    type="button"
                                    class="btn btn-outline-success btn-sm rounded-pill mt-2"
                                    @onclick="AddIngredient">
                                    <i class="bi bi-plus-circle me-1"></i>Ajouter un ingrédient
                                </button>
                            </div>
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" @bind="recipe.IsPublic" id="isPublic">
                            <label class="form-check-label" for="isPublic">
                                Rendre cette recette publique (visible à la communauté)
                            </label>
                        </div>

                        <div class="d-flex gap-2">
                            <button class="btn btn-primary" @onclick="SaveRecipe" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                Enregistrer
                            </button>
                            <button class="btn btn-outline-secondary" @onclick="GoBack">Annuler</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm sticky-top" style="top: 20px;">
                    <div class="card-body">
                        <h5 class="card-title">Aperçu</h5>
                        @if (!string.IsNullOrEmpty(recipe.ImageUrl))
                        {
                            <img src="@recipe.ImageUrl" alt="@recipe.Title" class="img-fluid rounded mb-3" />
                        }
                        else
                        {
                            <div class="bg-light rounded p-4 text-center mb-3">
                                <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                            </div>
                        }
                        <h6>@recipe.Title</h6>
                        <p class="text-muted small">
                            @if (!string.IsNullOrEmpty(recipe.Category))
                            {
                                <span class="badge bg-info">@recipe.Category</span>
                            }
                            @if (!string.IsNullOrEmpty(recipe.Area))
                            {
                                <span class="badge bg-secondary">@recipe.Area</span>
                            }
                        </p>
                        <p class="text-muted small">Créée le: @recipe.CreatedAt.ToString("dd/MM/yyyy")</p>
                    </div>
                </div>

                <div class="card border-2 border-danger mt-4 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-exclamation-diamond text-danger me-2" style="font-size: 1.5rem;"></i>
                            <h5 class="card-title mb-0 text-danger fw-bold">Zone de danger</h5>
                        </div>
                        <p class="text-muted small mb-3">Supprimer cette recette est une action <strong>irréversible</strong>. L'image et toutes les données seront supprimées.</p>
                        <button class="btn btn-danger btn-sm w-100 rounded-3" @onclick="ConfirmDelete" disabled="@isSaving">
                            <i class="bi bi-trash-fill me-2"></i>Supprimer définitivement
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string? RecipeId { get; set; }

    private RecetteUtilisateurDTO? recipe;
    private bool isLoading = true;
    private bool isSaving = false;
    private string? errorMessage;
    private string? successMessage;
    private List<string> categories = new();
    private List<string> areas = new();
    private bool isLoadingCategories = false;
    private bool isLoadingAreas = false;
    private bool imageLoadFailed = false;
    private string? urlInput;
    private string? originalImageUrl;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecipe();
        await LoadCategories();
        await LoadAreas();
    }

    private async Task LoadRecipe()
    {
        try
        {
            isLoading = true;
            if (string.IsNullOrEmpty(RecipeId))
            {
                errorMessage = "ID de recette manquant";
                return;
            }

            recipe = await UserRecipeService.GetByIdAsync(RecipeId);
            if (recipe == null)
            {
                errorMessage = "Recette non trouvée";
            }
            else
            {
                originalImageUrl = recipe.ImageUrl;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadCategories()
    {
        try
        {
            isLoadingCategories = true;
            categories = await RecipeService.GetCategoriesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur lors du chargement des catégories";
        }
        finally
        {
            isLoadingCategories = false;
        }
    }

    private async Task LoadAreas()
    {
        try
        {
            isLoadingAreas = true;
            areas = await RecipeService.GetAreasAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur lors du chargement des régions";
        }
        finally
        {
            isLoadingAreas = false;
        }
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;

            if (file != null)
            {
                // Vérifier la taille du fichier (max 5MB)
                const long maxFileSize = 5 * 1024 * 1024; // 5MB
                if (file.Size > maxFileSize)
                {
                    errorMessage = "L'image est trop grande (max 5MB)";
                    return;
                }

                // Vérifier le type MIME
                var validTypes = new[] { "image/jpeg", "image/png", "image/gif", "image/webp" };
                if (!validTypes.Contains(file.ContentType))
                {
                    errorMessage = "Format d'image non supporté";
                    return;
                }

                // Upload le fichier vers le serveur
                var imageUrl = await UploadService.UploadImageAsync(file);

                if (!string.IsNullOrEmpty(imageUrl))
                {
                    recipe!.ImageUrl = imageUrl;
                    errorMessage = null;
                    imageLoadFailed = false;
                }
                else
                {
                    errorMessage = "Erreur lors de l'upload de l'image";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement de l'image : {ex.Message}";
        }
    }

    private void SetImageFromUrl(string? url)
    {
        if (!string.IsNullOrWhiteSpace(url))
        {
            // Valider que c'est une URL valide
            if (Uri.TryCreate(url, UriKind.Absolute, out var uriResult) &&
                (uriResult.Scheme == Uri.UriSchemeHttp || uriResult.Scheme == Uri.UriSchemeHttps))
            {
                recipe!.ImageUrl = url;
                errorMessage = null;
                imageLoadFailed = false;
            }
            else
            {
                errorMessage = "L'URL n'est pas valide. Veuillez entrer une URL HTTP ou HTTPS complète";
            }
        }
    }

    private void HandleImageError()
    {
        imageLoadFailed = true;
    }

    private void ClearImage()
    {
        recipe!.ImageUrl = null;
        urlInput = null;
        imageLoadFailed = false;
    }

    private async Task SaveRecipe()
    {
        try
        {
            isSaving = true;
            errorMessage = null;
            successMessage = null;

            if (recipe == null || string.IsNullOrWhiteSpace(recipe.Title))
            {
                errorMessage = "Le titre est obligatoire";
                return;
            }

            if (string.IsNullOrWhiteSpace(recipe.Instructions))
            {
                errorMessage = "Les instructions sont obligatoires";
                return;
            }

            // Créer une requête de mise à jour
            var request = new RequeteCreationRecetteUtilisateur
            {
                Title = recipe.Title,
                Category = recipe.Category,
                Area = recipe.Area,
                Instructions = recipe.Instructions,
                ImageUrl = recipe.ImageUrl,
                IsPublic = recipe.IsPublic,
                Ingredients = recipe.Ingredients ?? new List<string>()
            };

            // Mettre à jour la recette
            var result = await UserRecipeService.UpdateAsync(recipe.UserRecipeId, request);

            if (result != null)
            {
                successMessage = "Recette mise à jour avec succès";
                Nav.NavigateTo("/mes-creations");
            }
            else
            {
                errorMessage = "Erreur lors de la mise à jour";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ConfirmDelete()
    {
        if (recipe == null)
            return;

        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            "Êtes-vous sûr de vouloir supprimer cette recette ? Cette action est irréversible.");

        if (confirmed)
        {
            await DeleteRecipe();
        }
    }

    private async Task DeleteRecipe()
    {
        try
        {
            isSaving = true;
            errorMessage = null;

            if (recipe == null)
                return;

            bool result = await UserRecipeService.DeleteAsync(recipe.UserRecipeId);

            if (result)
            {
                successMessage = "Recette supprimée avec succès";
                Nav.NavigateTo("/mes-creations");
            }
            else
            {
                errorMessage = "Erreur lors de la suppression. Veuillez réessayer.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void AddIngredient()
    {
        if (recipe?.Ingredients != null)
        {
            recipe.Ingredients.Add("");
        }
    }

    private void RemoveIngredient(int index)
    {
        if (recipe?.Ingredients != null && index >= 0 && index < recipe.Ingredients.Count)
        {
            recipe.Ingredients.RemoveAt(index);
        }
    }

    private void GoBack() => Nav.NavigateTo("/mes-creations");
}
