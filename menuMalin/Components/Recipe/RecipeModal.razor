@using menuMalin.Models

@if (Recipe != null && IsOpen)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0, 0, 0, 0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 rounded-4 shadow-lg">

                @* Modal Header *@
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold fs-4">@Recipe.StrMeal</h5>
                    <button type="button" class="btn-close" @onclick="Close"></button>
                </div>

                @* Modal Body *@
                <div class="modal-body">
                    @* Image *@
                    <div class="mb-4">
                        <img src="@Recipe.StrMealThumb" class="img-fluid rounded-3 w-100" alt="@Recipe.StrMeal">
                    </div>

                    @* Badges *@
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        <span class="badge rounded-pill bg-success px-3 py-2">
                            <i class="bi bi-tag-fill me-1"></i> @Recipe.StrCategory
                        </span>
                        <span class="badge rounded-pill bg-secondary px-3 py-2">
                            <i class="bi bi-geo-alt-fill me-1"></i> @Recipe.StrArea
                        </span>
                    </div>

                    @* Ingrédients *@
                    <h6 class="fw-bold mb-3 text-success">
                        <i class="bi bi-cart-check me-2"></i>Ingrédients
                    </h6>
                    <ul class="list-group list-group-flush mb-4">
                        @foreach (var ing in modalIngredients)
                        {
                            <li class="list-group-item bg-transparent border-0 d-flex justify-content-between py-1">
                                <span>@ing.Name</span>
                                <span class="fw-bold text-muted">@ing.Measure</span>
                            </li>
                        }
                    </ul>

                    @* Instructions *@
                    <h6 class="fw-bold mb-3 text-success">
                        <i class="bi bi-journal-text me-2"></i>Instructions
                    </h6>
                    <div class="instruction-steps text-muted lh-lg">
                        @foreach (var step in instructionSteps)
                        {
                            <p>@step</p>
                        }
                    </div>
                </div>

                @* Modal Footer *@
                <div class="modal-footer border-0 pt-0">
                    @if (!string.IsNullOrEmpty(Recipe.StrYoutube))
                    {
                        <a href="@Recipe.StrYoutube" target="_blank" class="btn btn-outline-danger rounded-pill">
                            <i class="bi bi-youtube me-2"></i>Voir sur YouTube
                        </a>
                    }
                    <button type="button" class="btn btn-success rounded-pill" @onclick="Close">
                        Fermer
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Recipe? Recipe { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    public bool IsOpen { get; set; } = false;

    private List<(string Name, string Measure)> modalIngredients = new();
    private List<string> instructionSteps = new();

    protected override void OnParametersSet()
    {
        ParseIngredients();
        ParseInstructions();
    }

    public async Task Open()
    {
        IsOpen = true;
        await InvokeAsync(StateHasChanged);
    }

    public async Task Close()
    {
        IsOpen = false;
        await OnClose.InvokeAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void ParseIngredients()
    {
        modalIngredients.Clear();
        if (Recipe == null) return;

        for (int i = 1; i <= 20; i++)
        {
            var ingredient = Recipe.GetType().GetProperty($"StrIngredient{i}")?.GetValue(Recipe) as string;
            var measure = Recipe.GetType().GetProperty($"StrMeasure{i}")?.GetValue(Recipe) as string;

            if (!string.IsNullOrWhiteSpace(ingredient))
            {
                modalIngredients.Add((ingredient, measure ?? ""));
            }
        }
    }

    private void ParseInstructions()
    {
        instructionSteps.Clear();
        if (Recipe == null || string.IsNullOrEmpty(Recipe.StrInstructions)) return;

        var steps = Recipe.StrInstructions.Split(new[] { ". ", "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries);
        instructionSteps = steps.ToList();
    }
}
