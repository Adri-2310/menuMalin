@using menuMalin.Models

@if (Recipes == null || !Recipes.Any())
{
    <div class="alert alert-info text-center rounded-4" role="alert">
        <i class="bi bi-info-circle me-2"></i>
        Aucune recette à afficher
    </div>
}
else
{
    @* AFFICHAGE DE LA GRILLE *@
    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
        @foreach (var recipe in GetPaginatedRecipes())
        {
            <div class="col">
                <RecipeCard Recipe="recipe" />
            </div>
        }
    </div>

    @* PAGINATION *@
    @if (TotalPages > 1)
    {
        <nav aria-label="Pagination" class="d-flex justify-content-center">
            <ul class="pagination">
                <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="PreviousPage" disabled="@(CurrentPage == 1)">
                        <i class="bi bi-chevron-left me-1"></i>Précédent
                    </button>
                </li>

                @for (int i = 1; i <= TotalPages; i++)
                {
                    var pageNum = i;
                    <li class="page-item @(CurrentPage == pageNum ? "active" : "")">
                        <button class="page-link" @onclick="@(() => GoToPage(pageNum))">
                            @pageNum
                        </button>
                    </li>
                }

                <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="NextPage" disabled="@(CurrentPage == TotalPages)">
                        Suivant<i class="bi bi-chevron-right ms-1"></i>
                    </button>
                </li>
            </ul>
        </nav>
    }
}

@code {
    private const int ITEMS_PER_PAGE = 6;

    [Parameter]
    public List<Recipe>? Recipes { get; set; }

    private int CurrentPage { get; set; } = 1;

    private int TotalPages => Recipes == null ? 0 : (int)Math.Ceiling((double)Recipes.Count / ITEMS_PER_PAGE);

    protected override void OnParametersSet()
    {
        // Reset pagination quand les recettes changent
        CurrentPage = 1;
    }

    private List<Recipe> GetPaginatedRecipes()
    {
        if (Recipes == null) return new List<Recipe>();

        var startIndex = (CurrentPage - 1) * ITEMS_PER_PAGE;
        return Recipes.Skip(startIndex).Take(ITEMS_PER_PAGE).ToList();
    }

    private void NextPage()
    {
        if (CurrentPage < TotalPages)
        {
            CurrentPage++;
        }
    }

    private void PreviousPage()
    {
        if (CurrentPage > 1)
        {
            CurrentPage--;
        }
    }

    private void GoToPage(int pageNum)
    {
        if (pageNum >= 1 && pageNum <= TotalPages)
        {
            CurrentPage = pageNum;
        }
    }
}
