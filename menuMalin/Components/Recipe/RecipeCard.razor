@using menuMalin.Models
@using menuMalin.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IFavoriteService FavoriteService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="card h-100 border-0 shadow-sm recipe-card transition-all">
    @* Image de la recette *@
    <div class="position-relative overflow-hidden rounded-4">
        <img src="@Recipe.StrMealThumb" class="card-img-top hover-zoom" alt="@Recipe.StrMeal">
        
        <div class="category-badge">
            <span class="badge rounded-pill bg-success-blur px-3 py-2">
                @Recipe.StrCategory
            </span>
        </div>
    </div>

    <div class="card-body px-2 py-3">
        <h5 class="card-title fw-bold text-dark mb-3">@Recipe.StrMeal</h5>
        
        <div class="d-flex justify-content-between align-items-center mt-auto">
            <a href="/recipe/@Recipe.IdMeal" class="btn btn-sm btn-success rounded-pill px-4 fw-bold">
                Voir plus
            </a>

            @* BOUTON COEUR ACTIF *@
            <button class="btn btn-favorite rounded-circle shadow-sm" @onclick="ToggleFavorite">
                @if (isFavorite)
                {
                    <i class="bi bi-heart-fill text-danger animate-pop"></i>
                }
                else
                {
                    <i class="bi bi-heart text-danger"></i>
                }
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] 
    public Recipe Recipe { get; set; } = new();

    private bool isFavorite = false;

    // Au chargement du composant, on vérifie si c'est déjà un favori
    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Recipe.IdMeal))
        {
            isFavorite = await FavoriteService.IsFavoriteAsync(Recipe.IdMeal);
        }
    }

    private async Task ToggleFavorite()
    {
        // Optionnel : Forcer la connexion pour mettre en favori
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!authState.User.Identity.IsAuthenticated)
        {
            Nav.NavigateTo("authentication/login");
            return;
        }

        if (isFavorite)
        {
            // On retire
            await FavoriteService.RemoveFavoriteAsync(Recipe.IdMeal);
            isFavorite = false;
        }
        else
        {
            // On ajoute
            await FavoriteService.AddFavoriteAsync(Recipe);
            isFavorite = true;
        }
    }
}