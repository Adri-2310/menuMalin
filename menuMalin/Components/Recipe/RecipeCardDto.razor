@using menuMalin.Services
@using menuMalin.Shared.Models.Dtos
@inject IFavoriteServiceFrontend FavoriteService
@inject IAuthService AuthService
@inject NavigationManager Nav

<div class="card h-100 border-0 shadow-sm recipe-card transition-all">
    @* Image de la recette *@
    <div class="position-relative overflow-hidden rounded-4">
        <img src="@Recipe.ImageUrl" class="card-img-top hover-zoom" alt="@Recipe.Title"
             onerror="this.src='images/placeholder.png'">

        <div class="category-badge">
            <span class="badge rounded-pill bg-success-blur px-3 py-2">
                @Recipe.Category
            </span>
        </div>
    </div>

    <div class="card-body px-2 py-3">
        <h5 class="card-title fw-bold text-dark mb-3">@Recipe.Title</h5>

        <div class="d-flex justify-content-between align-items-center mt-auto">
            <a href="/recipe/@Recipe.RecipeId" class="btn btn-sm btn-success rounded-pill px-4 fw-bold">
                Voir plus
            </a>

            @* BOUTON COEUR ACTIF *@
            <button class="btn btn-favorite rounded-circle shadow-sm" @onclick="ToggleFavorite" disabled="@isToggling">
                @if (isFavorite)
                {
                    <i class="bi bi-heart-fill text-danger animate-pop"></i>
                }
                else
                {
                    <i class="bi bi-heart text-danger"></i>
                }
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public RecipeDto Recipe { get; set; } = new();

    private bool isFavorite = false;
    private bool isToggling = false;

    // Au chargement du composant, on vérifie si c'est déjà un favori
    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Recipe.RecipeId))
        {
            isFavorite = await FavoriteService.IsFavoriteAsync(Recipe.RecipeId);
        }
    }

    private async Task ToggleFavorite()
    {
        try
        {
            isToggling = true;

            // Vérifier l'authentification
            var user = await AuthService.GetCurrentUserAsync();
            if (user?.IsAuthenticated != true)
            {
                Nav.NavigateTo("/");
                return;
            }

            if (isFavorite)
            {
                // On retire
                await FavoriteService.RemoveFavoriteAsync(Recipe.RecipeId);
                isFavorite = false;
            }
            else
            {
                // On ajoute
                await FavoriteService.AddFavoriteAsync(Recipe.RecipeId);
                isFavorite = true;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du toggle favori: {ex.Message}");
        }
        finally
        {
            isToggling = false;
        }
    }
}
