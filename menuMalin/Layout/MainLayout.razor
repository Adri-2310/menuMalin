@inherits LayoutComponentBase

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm border-bottom">
    <div class="container">
        @* --- LOGO --- *@
        <a class="navbar-brand d-flex align-items-center fw-bold" href="">
            <img src="images/logo.png" alt="Logo" width="35" height="35" class="me-2 logo-circle">
            <span style="color: #2d6a4f;">MenuMalin</span>
        </a>

        @* --- BOUTON HAMBURGER (C# Toggle) --- *@
        <button class="navbar-toggler" type="button" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        @* --- CONTENU DU MENU --- *@
        <div class="@NavMenuCssClass navbar-collapse" id="navbarNavMenu">
            
            @* NAVIGATION CENTRÉE *@
            <ul class="navbar-nav mx-auto text-center">
                <li class="nav-item">
                    <NavLink class="nav-link px-3" href="" Match="NavLinkMatch.All">Accueil</NavLink>
                </li>
                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item">
                            <NavLink class="nav-link px-3" href="favorites">Mes Favoris</NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link px-3" href="shopping-list">Liste de courses</NavLink>
                        </li>
                    </Authorized>
                </AuthorizeView>
            </ul>

            @* AUTHENTIFICATION (Centrée sur mobile, à droite sur PC) *@
            <div class="d-flex flex-column flex-lg-row align-items-center justify-content-center">
                <AuthorizeView>
                    <Authorized>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-light dropdown-toggle border-0" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> @context.User.Identity?.Name
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 text-center text-lg-start">
                                <li><a class="dropdown-item text-danger" href="authentication/logout">Déconnexion</a></li>
                            </ul>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <a href="authentication/login" class="btn btn-sm btn-link text-decoration-none text-muted mb-2 mb-lg-0 me-lg-2">
                            Connexion
                        </a>
                        <a href="authentication/register" class="btn btn-sm btn-success px-4 shadow-sm fw-bold">
                            Créer un compte
                        </a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
</nav>

<main>
    @Body
</main>

@code {
    // Logique pour le menu mobile
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}